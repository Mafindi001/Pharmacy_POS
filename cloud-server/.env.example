# RxPOS Cloud Sync Gateway — environment configuration
# Copy this file to `.env` (which is gitignored) and fill in real values.
# The cloud gateway is only needed ONLINE: to mint store API keys during
# installation and for optional background sync. The local POS runs fully
# offline over the LAN without it.

# --- Admin console (/admin) ---
# The admin panel is DISABLED until CLOUD_ADMIN_PASS is set. Use a long,
# unique secret. On a hosted deploy (e.g. Render) set these in the host's
# environment-variables dashboard instead of committing them.
CLOUD_ADMIN_USER=admin
CLOUD_ADMIN_PASS=change-me-to-a-long-random-secret

# --- Server ---
PORT=5000

# --- Database ---
# Leave DATABASE_URL unset to use the local SQLite fallback (cloud_central.db).
# Set it to your Postgres/Supabase connection string for production.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
